<Window x:Class="WpfApp3.SongEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Song"
        Width="440"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Text="Title" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1" Text="Artist" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Artist}" Height="28" Margin="0,0,0,8" />
            <TextBlock Grid.Row="2" Text="Album" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Album}" Height="28" Margin="0,0,0,8" />
            <TextBlock Grid.Row="3" Text="Genre" VerticalAlignment="Center" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Genre}" Height="28" Margin="0,0,0,8" />
            <TextBlock Grid.Row="4" Text="Year" VerticalAlignment="Center" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Year}" Height="28" />
        </Grid>

        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
            <Border Width="96" Height="96" Background="#D6DAE2" CornerRadius="6" ClipToBounds="True">
                <Image Source="{Binding CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
            </Border>
            <Button Content="Browse cover..."
                    Command="{Binding BrowseCoverCommand}"
                    Style="{StaticResource QuietButtonStyle}"
                    Margin="0,10,0,0"
                    Padding="8,5" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}" MinWidth="74" Margin="0,0,8,0" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource QuietButtonStyle}" MinWidth="74" />
        </StackPanel>
    </Grid>
</Window>
