<UserControl x:Class="WpfApp3.Views.PlaylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="74" Height="74" Background="#D6DAE2" CornerRadius="6" ClipToBounds="True">
                <Image Source="{Binding Playlist.CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
            </Border>
            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Playlist.Name}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}" />
                <TextBlock Text="{Binding Playlist.SongCount, StringFormat={}{0} songs}" Foreground="#596273" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Play" Command="{Binding PlayPlaylistCommand}" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Remove" Command="{Binding RemoveSelectedSongCommand}" Style="{StaticResource QuietButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Up" Command="{Binding MoveSelectedSongUpCommand}" Style="{StaticResource QuietButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Down" Command="{Binding MoveSelectedSongDownCommand}" Style="{StaticResource QuietButtonStyle}" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Playlist.Songs}"
                  SelectedItem="{Binding SelectedSong, Mode=TwoWay}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play" Command="{Binding PlacementTarget.DataContext.PlaySelectedSongCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="Edit..." Command="{Binding PlacementTarget.DataContext.EditSelectedSongCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="Remove from playlist" Command="{Binding PlacementTarget.DataContext.RemoveSelectedSongCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="48">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="30" Height="30" Background="#D6DAE2" CornerRadius="4" ClipToBounds="True">
                                <Image Source="{Binding CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="*" />
                <DataGridTextColumn Header="Album" Binding="{Binding Album}" Width="*" />
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*" />
                <DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
