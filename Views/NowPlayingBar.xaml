<UserControl x:Class="WpfApp3.Views.NowPlayingBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="56">
    <Grid Background="{StaticResource PrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="180" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Column="0">
            <Border Width="56" Height="56" Background="{StaticResource PlaceholderBrush}">
                <Image Source="{Binding CurrentSong.CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock Text="{Binding CurrentSong.Title, TargetNullValue=Nothing playing}"
                           Foreground="{StaticResource LightTextBrush}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Width="180" />
                <TextBlock Text="{Binding CurrentSong.Artist}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Width="180" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Prev" Command="{Binding PreviousCommand}" Style="{StaticResource QuietButtonStyle}" Padding="8,4" Margin="0,0,6,0" />
            <Button Grid.Column="1" Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}" Style="{StaticResource AccentButtonStyle}" Padding="10,4" Margin="0,0,6,0" />
            <Button Grid.Column="2" Content="Next" Command="{Binding NextCommand}" Style="{StaticResource QuietButtonStyle}" Padding="8,4" Margin="0,0,10,0" />
            <TextBlock Grid.Column="3" Text="{Binding PositionDisplay}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
            <Slider Grid.Column="4" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="5" Text="{Binding DurationDisplay}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
            <TextBlock Text="Volume" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Slider Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" Width="90" />
        </StackPanel>
    </Grid>
</UserControl>
