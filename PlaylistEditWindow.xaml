<Window x:Class="WpfApp3.PlaylistEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist"
        Width="360"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="110" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="Name" FontWeight="SemiBold" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center">
            <Border Width="80" Height="80" Background="#D6DAE2" CornerRadius="6" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
                    <TextBlock Text="No Cover"
                               Foreground="#596273"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasCover, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                </Grid>
            </Border>
            <Button Content="Browse cover..."
                    Command="{Binding BrowseCoverCommand}"
                    Style="{StaticResource QuietButtonStyle}"
                    Margin="0,10,0,0"
                    Padding="8,5" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}" MinWidth="74" Margin="0,0,8,0" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource QuietButtonStyle}" MinWidth="74" />
        </StackPanel>
    </Grid>
</Window>
