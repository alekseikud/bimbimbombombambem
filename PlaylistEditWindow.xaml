<Window x:Class="WpfApp3.PlaylistEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Playlist"
        Width="360"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="110" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="Name" FontWeight="SemiBold" />
            <TextBox x:Name="NameTextBox"
                     Height="30"
                     Margin="0,6,0,0"
                     TextChanged="NameTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
            <Border Width="80"
                    Height="80"
                    Background="#D6DAE2"
                    CornerRadius="6"
                    ClipToBounds="True">
                <Grid>
                    <Image x:Name="CoverImage" Stretch="UniformToFill" />
                    <TextBlock x:Name="NoCoverText"
                               Text="No Cover"
                               Foreground="#596273"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
            <Button Content="Browse cover..."
                    Click="BrowseCover_Click"
                    Margin="0,10,0,0"
                    Padding="8,5" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Click="Save_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    MinWidth="74"
                    Margin="0,0,8,0"
                    IsEnabled="False" />
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    MinWidth="74"
                    Padding="12,6" />
        </StackPanel>
    </Grid>
</Window>
