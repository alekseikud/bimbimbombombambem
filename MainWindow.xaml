<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WpfApp3.Views"
        Title="Musica"
        Icon="Resources/vinyl.ico"
        Height="600"
        Width="1000"
        MinHeight="480"
        MinWidth="800">
    <DockPanel Background="{StaticResource SurfaceBrush}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Library">
                <MenuItem Header="New..." Command="{Binding NewLibraryCommand}" />
                <MenuItem Header="Open..." Command="{Binding OpenLibraryCommand}" />
                <Separator />
                <MenuItem Header="Save" InputGestureText="Ctrl+S" Command="{Binding SaveLibraryCommand}" />
            </MenuItem>
            <MenuItem Header="Songs">
                <MenuItem Header="Import..." Command="{Binding ImportSongsCommand}" />
                <MenuItem Header="Edit..." Command="{Binding EditSelectedSongCommand}" />
                <MenuItem Header="Delete" InputGestureText="Del" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="Playlist">
                <MenuItem Header="New..." Command="{Binding CreatePlaylistCommand}" />
                <MenuItem Header="Rename" Command="{Binding RenameSelectedPlaylistCommand}" />
                <MenuItem Header="Delete" Command="{Binding DeleteSelectedPlaylistCommand}" />
            </MenuItem>
        </Menu>

        <views:NowPlayingBar DockPanel.Dock="Bottom" DataContext="{Binding Player}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource SideBarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Command="{Binding ShowAllSongsCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Image Source="Resources/vinyl.png" Width="34" Height="34" Margin="0,0,10,0" />
                        <TextBlock Text="All Songs" FontSize="18" FontWeight="Bold" Foreground="{StaticResource LightTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="1" Margin="14,0">
                    <TextBlock Text="PLAYLISTS"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button Content="+"
                            Command="{Binding CreatePlaylistCommand}"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="0" />
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Library.Playlists}"
                         SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource LightTextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Rename" Command="{Binding PlacementTarget.DataContext.RenameSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Delete" Command="{Binding PlacementTarget.DataContext.DeleteSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#304158" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" Background="{StaticResource PlaceholderBrush}" CornerRadius="4" ClipToBounds="True">
                                    <Image Source="{Binding CoverArt, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding Name}" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            Margin="20" />
        </Grid>
    </DockPanel>
</Window>
