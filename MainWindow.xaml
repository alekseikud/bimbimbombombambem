<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musica"
        Icon="Resources/vinyl.ico"
        Height="600"
        Width="1000"
        MinHeight="480"
        MinWidth="800">
    <DockPanel Background="{StaticResource SurfaceBrush}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Library">
                <MenuItem Header="New..." Command="{Binding NewLibraryCommand}" />
                <MenuItem Header="Open..." Command="{Binding OpenLibraryCommand}" />
                <MenuItem Header="Save" InputGestureText="Ctrl+S" Command="{Binding SaveLibraryCommand}" />
            </MenuItem>
            <MenuItem Header="Songs">
                <MenuItem Header="Import..." />
                <MenuItem Header="Edit..." />
                <MenuItem Header="Delete" InputGestureText="Del" />
            </MenuItem>
            <MenuItem Header="Playlist">
                <MenuItem Header="New..." Command="{Binding CreatePlaylistCommand}" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Height="56" Background="{StaticResource PrimaryBrush}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource SideBarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Image Source="Resources/vinyl.png" Width="34" Height="34" Margin="0,0,10,0" />
                    <TextBlock Text="All Songs"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource LightTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="14,0">
                    <TextBlock Text="PLAYLISTS"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button Content="+"
                            Command="{Binding CreatePlaylistCommand}"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="0" />
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Playlists}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource LightTextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#304158" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource PlaceholderBrush}"
                                        CornerRadius="4"
                                        ClipToBounds="True">
                                    <Image Source="{Binding CoverPath}" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding Name}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Grid Grid.Column="1" Margin="20">
                <Grid Visibility="{Binding WelcomeVisibility}">
                    <StackPanel Width="360" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="Resources/vinyl.png" Width="86" Height="86" Margin="0,0,0,18" />
                        <TextBlock Text="Musica"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#20242C"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Create a new music library or open an existing one."
                                   TextWrapping="Wrap"
                                   Foreground="#596273"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   Margin="0,8,0,26" />
                        <Button Content="Create New Library"
                                Command="{Binding Welcome.CreateLibraryCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="38"
                                Margin="0,0,0,10" />
                        <Button Content="Open Existing Library"
                                Command="{Binding Welcome.OpenLibraryCommand}"
                                Height="38"
                                Padding="12,6" />
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding LibraryVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBox Width="600"
                                 Height="30"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Text="Search songs"
                                 Foreground="Gray"
                                 Background="White" />
                        <Button Content="Import songs"
                                Width="120"
                                Height="30"
                                HorizontalAlignment="Right"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False" />
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Songs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="*" />
                            <DataGridTextColumn Header="Album" Binding="{Binding Album}" Width="*" />
                            <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80" />
                            <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
