<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000" MinHeight="480" MinWidth="800">
    <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="Library">
                    <MenuItem Header="New..."></MenuItem>
                    <MenuItem Header="Open..."></MenuItem>
                    <MenuItem Header="Save" InputGestureText="Ctrl+S"></MenuItem>
                </MenuItem>
                <MenuItem Header="Songs">
                    <MenuItem Header="Import..."></MenuItem>
                    <MenuItem Header="Edit..."></MenuItem>
                    <MenuItem Header="Delete" InputGestureText="Del"></MenuItem>
                </MenuItem>
                <MenuItem Header="Playlist">
                    <MenuItem Header="New..."></MenuItem>
                </MenuItem>
            </Menu>
        <Border DockPanel.Dock="Bottom" Height="56" Background="{StaticResource PrimaryBrush}">  </Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource SideBarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"></RowDefinition>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="♭" FontSize="28" Foreground="{StaticResource AccentBrush}"  Margin="0,0,10,0"></TextBlock>
                    <TextBlock Text="All Songs" FontSize="18" FontWeight="Bold" Foreground="{StaticResource LightTextBrush}"/>
                    
                </StackPanel>

                <Grid Grid.Row="1" Margin="14,0">
                    <TextBlock Text="PLAYLISTS" Foreground="{StaticResource MutedTextBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"></TextBlock>
                    <Button Content="+" Width="30" Height="30" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold"></Button>
                </Grid>
                <ListView Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <!--image-->
                                <!--textblock-->
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <TextBox Width="600" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Search songs" Foreground="Gray" Background="white"></TextBox>
                    <Button Content="Import songs" Width="120" Height="30" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}"></Button>
                </Grid>
                <DataGrid Grid.Row="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header=""></DataGridTextColumn>
                        <DataGridTextColumn Header="Title" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Artist" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Album" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Genre" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Duration" Width="*"></DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>


    </DockPanel>

</Window>
